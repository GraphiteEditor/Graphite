{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"sourceMap": true,
		"types": ["node"],
		"paths": { "/*": ["./*"] },
		"lib": ["ESNext", "DOM", "DOM.Iterable"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "*.ts"]
}
